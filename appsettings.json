      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=BercaDb_Fresh;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "PushNotification": {
    "PublicKey": "BK8n_ZkYbQLPRNv4L3jQ8I9k2XGlbr9F2H5NJF9hA_D7YP2b8Z3QKqF5VGh7RWzMnT6yQ9B4_R5TJ7G2E8bKhA",
    "PrivateKey": "5VGh7RWzMnT6yQ9B4_R5TJ7G2E8bKhA3gF6H8Y9P2bL",
