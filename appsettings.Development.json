    "RetentionDays": 30,
    "MaxConcurrentReports": 2,
    "DefaultPageSize": 10,
    "MaxPageSize": 100,
    "CacheExpirationMinutes": 5,
    "ExportFormats": {
      "PDF": {
        "Enabled": true,
        "MaxPageSize": "A4",
        "Orientation": "Portrait",
        "Margins": {
          "Top": 15,
          "Bottom": 15,
          "Left": 15,
          "Right": 15
        },
        "WatermarkText": "Toko Eniwan - DEVELOPMENT",
        "IncludePageNumbers": true,
        "CompanyLogo": "/images/logo-dev.png",
        "FontFamily": "Arial",
        "FontSize": 9
      },
      "Excel": {
        "Enabled": true,
        "MaxRows": 10000,
        "IncludeCharts": false,
        "AutoFitColumns": true,
        "FreezeHeaders": true,
        "DefaultWorksheetName": "Dev Report",
        "CompanyName": "Toko Eniwan - Development",
        "HeaderBackgroundColor": "#FF6600",
        "HeaderFontColor": "#FFFFFF"
      },
      "CSV": {
        "Enabled": true,
        "Delimiter": ",",
        "Encoding": "UTF-8",
        "IncludeHeaders": true,
        "QuoteStrings": true,
        "MaxRows": 50000
      }
    },
    "Templates": {
      "DefaultTemplate": "Development",
      "TemplatePath": "Templates/Reports/Dev/",
      "CustomTemplatesEnabled": true
    },
    "EmailSettings": {
      "Enabled": false,
      "SmtpHost": "localhost",
      "SmtpPort": 25,
      "Username": "dev@localhost",
      "Password": "dev-password",
      "EnableSsl": false,
      "FromName": "Toko Eniwan Dev Reports",
      "FromEmail": "dev-reports@localhost",
      "MaxAttachmentSizeMB": 10,
      "DefaultSubject": "[DEV] Laporan dari Toko Eniwan",
      "BodyTemplate": "Development report attached. For testing purposes only."
    },
    "BusinessIntelligence": {
      "Enabled": true,
      "RefreshIntervalMinutes": 15,
      "HistoricalDataMonths": 6,
      "PredictionModels": {
        "SalesForecasting": false,
        "InventoryOptimization": true,
        "CustomerSegmentation": false
      },
      "PerformanceMetrics": {
        "SalesGrowthThreshold": 0.10,
        "ProfitMarginTarget": 0.20,
        "InventoryTurnoverTarget": 6,
        "CustomerRetentionTarget": 0.70
      }
    },
    "Security": {
      "EncryptSensitiveData": false,
      "RequireAuthentication": false,
      "AllowedRoles": ["Admin", "Manager", "User", "Developer"],
      "AuditReportAccess": false,
      "DataMaskingEnabled": false
    },
    "Performance": {
      "QueryTimeoutSeconds": 120,
      "MaxMemoryUsageMB": 256,
      "EnableBackgroundProcessing": false,
      "MaxQueueSize": 10,
      "Compression": {
        "Enabled": false,
        "Level": "Fastest",
        "MinFileSizeKB": 500
      }
    }
